<UserControl x:Class="PLCSharp.VVMs.Homepage.TableControl.RangeTable"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PLCSharp.VVMs.Homepage.TableControl"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:RangeTableViewModel}"
             d:Height="300" d:Width="400"
             Background="AliceBlue">
    <Grid>
        <DataGrid Width="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualWidth}"
                  Height="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualHeight}"
                  HorizontalAlignment="Center" VerticalAlignment="Center"
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  CanUserDeleteRows="False" CanUserSortColumns="False"
                  ItemsSource="{Binding RangeValues}"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  Unloaded="DataGrid_Unloaded">
            <DataGrid.Columns>
                <DataGridTextColumn MinWidth="50" IsReadOnly="True" Binding="{Binding Name}" Header="名称" />
                <DataGridTextColumn MinWidth="50" IsReadOnly="True" Binding="{Binding MinValue}" Header="最小值" />
                <DataGridTextColumn MinWidth="50" IsReadOnly="True" Binding="{Binding MaxValue}" Header="最大值" />
                <DataGridTextColumn MinWidth="50" IsReadOnly="True" Binding="{Binding BaseValue}" Header="标准值" />
                <DataGridTextColumn MinWidth="50" IsReadOnly="True" Binding="{Binding ShowValue, UpdateSourceTrigger=LostFocus}" Header="检测值" />
                <DataGridTextColumn MinWidth="50" IsReadOnly="True" Binding="{Binding Offs}" Header="偏差" />
                <DataGridTextColumn MinWidth="50" IsReadOnly="True" Binding="{Binding ResultStr}" Header="结果">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Center" />
                            <Style.Triggers>
                                <Trigger Property="Text" Value="OK">
                                    <Setter Property="Background" Value="Lime" />
                                </Trigger>
                                <Trigger Property="Text" Value="NG">
                                    <Setter Property="Background" Value="Red" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>

</UserControl>