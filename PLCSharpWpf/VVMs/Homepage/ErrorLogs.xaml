<UserControl x:Class="PLCSharp.VVMs.Homepage.ErrorLogs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PLCSharp.VVMs.Homepage"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:ErrorLogsViewModel}"
             d:DesignHeight="450" d:DesignWidth="800"
             MinHeight="200 "
             Background="AliceBlue">
    <prism:Dialog.WindowStyle>
        <Style TargetType="Window">
            <Setter Property="SizeToContent" Value="Height" />
        </Style>
    </prism:Dialog.WindowStyle>
    <Grid>
        <GroupBox Grid.Row="1" Header="消息">
            <Grid>
                <DataGrid Width="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualWidth}"
                          Height="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualHeight}"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          CanUserDeleteRows="False" CanUserSortColumns="False"
                          ItemsSource="{Binding Model.ErrorLogs}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          Unloaded="DataGrid_Unloaded">
                    <DataGrid.ItemContainerStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConfirm}" Value="False">
                                    <Setter Property="Foreground" Value="Red" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsConfirm}" Value="True">
                                    <Setter Property="Foreground" Value="Black" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.ItemContainerStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn MinWidth="160" Binding="{Binding Time, UpdateSourceTrigger=LostFocus}" Header="触发时间" />
                        <DataGridTextColumn MinWidth="1000" Binding="{Binding Message, UpdateSourceTrigger=LostFocus}" Header="消息" />
                        <DataGridTemplateColumn Header="确认">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsConfirm, UpdateSourceTrigger=LostFocus}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
