<UserControl x:Class="PLCSharp.VVMs.Connects.Socket.SocketServerConfig"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beavior="clr-namespace:PLCSharp.Core.Prism"
             xmlns:cvt="clr-namespace:PLCSharp.Core.Tools"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:local="clr-namespace:PLCSharp.VVMs.Connects.Socket"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:viewmodels="clr-namespace:PLCSharp.VVMs.Connects.Socket"
             xmlns:connects="clr-namespace:PLCSharp.VVMs.Connects"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" d:Background="White"
             d:DataContext="{d:DesignInstance Type=local:SocketServerConfigViewModel}"
             Width="900" Height="400">
    <UserControl.Resources>
        <cvt:BoolToValueConverter x:Key="BoolToValueConverter" />

        <ObjectDataProvider x:Key="DataType" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="connects:CommunicationDataType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

    </UserControl.Resources>

    <Grid>
        <GroupBox Header="客户端">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="30" />
                </Grid.RowDefinitions>
                <Grid>
                    <Grid>
                        <Grid.RowDefinitions>

                            <RowDefinition Height="*" />
                            <RowDefinition Height="3*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <DataGrid Width="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualWidth}"
                                      Height="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualHeight}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      AutoGenerateColumns="False" CanUserAddRows="False"
                                      CanUserDeleteRows="False" CanUserSortColumns="False"
                                      ItemsSource="{Binding Server.Clients}"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      SelectedItem="{Binding SelectedClient}"
                                      Unloaded="DataGrid_Unloaded">
                                <DataGrid.ItemContainerStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Params.Prompt}" Value="已修改，请保存">
                                                <Setter Property="Foreground" Value="Red" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Params.Prompt}" Value="">
                                                <Setter Property="Foreground" Value="Black" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.ItemContainerStyle>
                                <DataGrid.ContextMenu>
                                    <ContextMenu IsEnabled="True" StaysOpen="False">
                                        <MenuItem Command="{Binding ConnectsManage}" CommandParameter="New" Header="新增" />
                                        <MenuItem Command="{Binding ConnectsManage}" CommandParameter="Remove" Header="删除" />
                                        <MenuItem Command="{Binding ConnectsManage}" CommandParameter="Save" Header="保存" />
                                        <MenuItem Command="{Binding ConnectsManage}" CommandParameter="Config" Header="配置" />
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.Columns>
                                    <DataGridTextColumn MinWidth="60" Binding="{Binding Name, UpdateSourceTrigger=LostFocus}" Header="连接名" />
                                    <DataGridTextColumn MinWidth="100" Binding="{Binding IP, UpdateSourceTrigger=LostFocus}" Header="IP" />
                                    <DataGridComboBoxColumn Width="150" Header="消息类型" ItemsSource="{Binding Source={StaticResource DataType}}" SelectedValueBinding="{Binding Params.DataType, UpdateSourceTrigger=PropertyChanged}" />
                                    <DataGridTextColumn MinWidth="100" Binding="{Binding Comment, UpdateSourceTrigger=LostFocus}" Header="备注" />
                                    <DataGridTemplateColumn Header="在线">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Viewbox>
                                                    <Ellipse Width="10" Height="10" Fill="{Binding Online, Converter={StaticResource BoolToValueConverter}, Mode=TwoWay, ConverterParameter=Lime, FallbackValue=Gray}" />
                                                </Viewbox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="连接">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Viewbox>
                                                    <Ellipse Width="10" Height="10" Fill="{Binding Connected, Converter={StaticResource BoolToValueConverter}, Mode=TwoWay, ConverterParameter=Lime, FallbackValue=Gray}" />
                                                </Viewbox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="读写">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Viewbox>
                                                    <Ellipse Width="10" Height="10" Fill="{Binding Successful, Converter={StaticResource BoolToValueConverter}, Mode=TwoWay, ConverterParameter=Lime, FallbackValue=Gray}" />
                                                </Viewbox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn MinWidth="100" Binding="{Binding Params.Prompt}" Header="提示" IsReadOnly="True" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                        <Grid Grid.Row="1">


                            <DataGrid Width="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualWidth}"
                                      Height="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualHeight}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      AutoGenerateColumns="False" CanUserAddRows="False"
                                      CanUserDeleteRows="False" CanUserSortColumns="False"
                                      ItemsSource="{Binding Logs}"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      Unloaded="DataGrid_Unloaded">
                                <i:Interaction.Behaviors>
                                    <beavior:DataGridScrollToBottomBehavior />
                                </i:Interaction.Behaviors>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Width="1*" Binding="{Binding Time, UpdateSourceTrigger=LostFocus}" Header="时间" />
                                    <DataGridTextColumn Width="5*" Binding="{Binding Message, UpdateSourceTrigger=LostFocus}" Header="消息" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </Grid>
                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <TextBox Width="600" Text="{Binding SendString, Mode=TwoWay}" TextWrapping="Wrap" AcceptsReturn="True" />
                    <Button Width="80" Command="{Binding Send}" Content="发送" />
                    <Button Width="80" Margin="10,0" Command="{Binding SendToAll}" Content="广播" />
                    <CheckBox Content="显示日志" IsChecked="{Binding Server.LogSwitch}" />
                </StackPanel>
                <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">


                    <TextBlock Margin="10,0" Text="服务器IP:    " VerticalAlignment="Center" />
                    <TextBox Width="150" Text="{Binding IP, UpdateSourceTrigger=LostFocus, ValidatesOnDataErrors=True}" VerticalAlignment="Center" />



                    <TextBlock Margin="10,0" Text="服务端口:" VerticalAlignment="Center" />
                    <TextBox Width="150" Text="{Binding Port, UpdateSourceTrigger=LostFocus, ValidatesOnDataErrors=True}" VerticalAlignment="Center" />

                    <TextBlock Margin="10,0" Text="在线:" VerticalAlignment="Center" />

                    <Ellipse Width="20" Height="20" Fill="{Binding Server.Online, Converter={StaticResource BoolToValueConverter}, Mode=TwoWay, ConverterParameter=Lime, FallbackValue=Gray}" />
                    <TextBlock Margin="10,0" Text="连接:" VerticalAlignment="Center" />

                    <Ellipse Width="20" Height="20" Fill="{Binding Server.Connected, Converter={StaticResource BoolToValueConverter}, Mode=TwoWay, ConverterParameter=Lime, FallbackValue=Gray}" />
                    <TextBlock Margin="10,0" Text="消息类型:" VerticalAlignment="Center" />

                </StackPanel>
            </Grid>


        </GroupBox>
    </Grid>
</UserControl>