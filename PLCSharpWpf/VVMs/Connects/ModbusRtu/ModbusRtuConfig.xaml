<UserControl x:Class="PLCSharp.VVMs.Connects.ModbusRtu.ModbusRtuConfig"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beavior="clr-namespace:PLCSharp.Core.Prism"
             xmlns:cvt="clr-namespace:PLCSharp.Core.Tools"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:local="clr-namespace:PLCSharp.VVMs.Connects.ModbusRtu"
             xmlns:mb="clr-namespace:PLCSharp.VVMs.Connects.ModbusTcp"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" d:Background="White"
             d:DataContext="{d:DesignInstance Type=local:ModbusRtuConfigViewModel}"
             Width="1000" Height="600">
    <UserControl.Resources>
        <cvt:BoolToValueConverter x:Key="BoolToValueConverter" />
        <ObjectDataProvider x:Key="ValueInterpretationValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="mb:DataItem+ValueInterpretationEnum" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <Grid>
        <GroupBox Header="Modbus RTU 客户端">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="2.5*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  串口参数  -->
                <GroupBox Header="串口设置">
                    <StackPanel Margin="5" Orientation="Horizontal">
                        <TextBlock Margin="5,0" Text="端口:" VerticalAlignment="Center" />
                        <TextBox Width="80" Text="{Binding Client.IP_SerialPort}" VerticalAlignment="Center" />
                        <Button Width="40" Margin="5,0" Content="打开" Command="{Binding OpenPortCommand}" />
                        <Button Width="40" Margin="5,0" Content="关闭" Command="{Binding ClosePortCommand}" />
                        <TextBlock Margin="10,0,0,0" Text="波特率:" VerticalAlignment="Center" />
                        <ComboBox Width="80" VerticalAlignment="Center" SelectedValuePath="Content" SelectedValue="{Binding Client.Params.BaudRate}">
                            <ComboBoxItem Content="9600" />
                            <ComboBoxItem Content="19200" />
                            <ComboBoxItem Content="38400" />
                            <ComboBoxItem Content="115200" />
                        </ComboBox>
                        <TextBlock Margin="10,0,0,0" Text="数据位:" VerticalAlignment="Center" />
                        <ComboBox Width="50" VerticalAlignment="Center" SelectedValuePath="Content" SelectedValue="{Binding Client.Params.DataBits}">
                            <ComboBoxItem Content="8" />
                            <ComboBoxItem Content="7" />
                        </ComboBox>
                        <TextBlock Margin="10,0,0,0" Text="停止位:" VerticalAlignment="Center" />
                        <ComboBox Width="50" VerticalAlignment="Center" SelectedValuePath="Content" SelectedValue="{Binding Client.Params.StopBitsValue}">
                            <ComboBoxItem Content="None" />
                            <ComboBoxItem Content="One" />
                            <ComboBoxItem Content="Two" />
                        </ComboBox>
                        <TextBlock Margin="10,0,0,0" Text="校验:" VerticalAlignment="Center" />
                        <ComboBox Width="80" VerticalAlignment="Center" SelectedValuePath="Content" SelectedValue="{Binding Client.Params.ParityValue}">
                            <ComboBoxItem Content="None" />
                            <ComboBoxItem Content="Odd" />
                            <ComboBoxItem Content="Even" />
                        </ComboBox>
                        <TextBlock Margin="10,0,0,0" Text="站号:" VerticalAlignment="Center" />
                        <TextBox Width="40" Text="{Binding Client.Params.UnitId}" VerticalAlignment="Center" />
                        <Button Width="40" Margin="5,0"
                                Content="保存"
                                Command="{Binding ConnectsManage}"
                                CommandParameter="Save" />
                    </StackPanel>
                </GroupBox>

                <!--  地址表  -->
                <GroupBox Grid.Row="1" Header="地址表">
                    <Grid>

                        <DataGrid Width="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualWidth}"
                                  Height="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualHeight}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  CanUserDeleteRows="False" CanUserSortColumns="True"
                                  ItemsSource="{Binding Client.DataItems}"
                                  SelectedItem="{Binding SelectedDataItem}"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.ContextMenu>
                                <ContextMenu IsEnabled="True" StaysOpen="False">
                                    <MenuItem Command="{Binding ConnectsManage}" CommandParameter="New" Header="新增" />
                                    <MenuItem Command="{Binding ConnectsManage}" CommandParameter="Remove" Header="删除" />
                                    <Separator />
                                    <MenuItem Command="{Binding ConnectsManage}" CommandParameter="Send" Header="发送数据" />
                                    <MenuItem Command="{Binding ConnectsManage}" CommandParameter="SendAll" Header="发送全部" />
                                    <Separator />
                                    <MenuItem Command="{Binding ConnectsManage}" CommandParameter="Save" Header="保存" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="0.8*" Binding="{Binding UnitId, UpdateSourceTrigger=LostFocus}" Header="站" />
                                <DataGridTextColumn Width="0.8*" Binding="{Binding Address, UpdateSourceTrigger=LostFocus}" Header="地址" />
                                <DataGridComboBoxColumn Width="1*" Header="解释" ItemsSource="{Binding Source={StaticResource ValueInterpretationValues}}" SelectedValueBinding="{Binding ValueInterpretation, UpdateSourceTrigger=PropertyChanged}" />
                                <DataGridTextColumn Width="1.2*" Binding="{Binding DisplayValue, Mode=OneWay}" Header="当前值" IsReadOnly="True" />
                                <DataGridTextColumn Width="1.2*" Binding="{Binding SendValue, UpdateSourceTrigger=LostFocus}" Header="发送值" />
                                <DataGridTextColumn Width="1.5*" Binding="{Binding Description, UpdateSourceTrigger=LostFocus}" Header="备注" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </GroupBox>

                <!--  轮询控制  -->
                <StackPanel Grid.Row="2" Margin="5" Orientation="Horizontal">
                    <CheckBox Margin="5,0" VerticalAlignment="Center" IsChecked="{Binding Client.PollEnabled}" Content="启用轮询" />
                    <TextBlock Margin="5,0" Text="间隔(ms):" VerticalAlignment="Center" />
                    <TextBox Width="80" Text="{Binding Client.PollIntervalMs, UpdateSourceTrigger=LostFocus}" VerticalAlignment="Center" />
                </StackPanel>

                <!--  日志  -->
                <GroupBox Grid.Row="3" Header="日志">
                    <DataGrid Width="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=2}, Path=ActualWidth}"
                              Height="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=2}, Path=ActualHeight}"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              CanUserDeleteRows="False" CanUserSortColumns="False"
                              ItemsSource="{Binding Logs}"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              Unloaded="DataGrid_Unloaded">
                        <i:Interaction.Behaviors>
                            <beavior:DataGridScrollToBottomBehavior />
                        </i:Interaction.Behaviors>
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="1*" Binding="{Binding Time, UpdateSourceTrigger=LostFocus}" Header="时间" />
                            <DataGridTextColumn Width="5*" Binding="{Binding Message, UpdateSourceTrigger=LostFocus}" Header="消息" />
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>

                <!--  显示日志复选框  -->
                <StackPanel Grid.Row="4" Margin="0,4" Orientation="Horizontal">
                    <CheckBox Margin="20,0,0,0" Content="显示日志" IsChecked="{Binding Client.LogSwitch}" />
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
