<UserControl x:Class="PLCSharp.VVMs.Connects.Connects"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:connect="clr-namespace:PLCSharp.VVMs.Connects"
             xmlns:cvt="clr-namespace:PLCSharp.Core.Tools"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PLCSharp.VVMs.Connects"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:ConnectsViewModel}"
             d:Height="350" d:Width="1000"
             Background="AliceBlue">
    <prism:Dialog.WindowStyle>
        <Style TargetType="Window">
            <Setter Property="SizeToContent" Value="Manual" />
        </Style>
    </prism:Dialog.WindowStyle>
    <UserControl.Resources>
        <ObjectDataProvider x:Key="ProtocolType" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="connect:ProtocolType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <cvt:BoolToValueConverter x:Key="BoolToValueConverter" />
    </UserControl.Resources>


    <UniformGrid>
        <GroupBox Header="连接">
            <Grid>
                <DataGrid Width="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualWidth}"
                          Height="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualHeight}"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          CanUserDeleteRows="False" CanUserSortColumns="False"
                          ItemsSource="{Binding ConnectsModel.Connects}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          SelectedItem="{Binding ConnectsModel.SelectedConnect}"
                          Unloaded="DataGrid_Unloaded">
                    <DataGrid.ItemContainerStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Params.Prompt}" Value="已修改，请保存">
                                    <Setter Property="Foreground" Value="Red" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Params.Prompt}" Value="">
                                    <Setter Property="Foreground" Value="Black" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.ItemContainerStyle>
                    <DataGrid.ContextMenu>
                        <ContextMenu IsEnabled="True" StaysOpen="False">
                            <MenuItem Command="{Binding ConnectsModel.ConnectsManage}" CommandParameter="New" Header="新增" />
                            <MenuItem Command="{Binding ConnectsModel.ConnectsManage}" CommandParameter="Remove" Header="删除" />
                            <MenuItem Command="{Binding ConnectsModel.ConnectsManage}" CommandParameter="Save" Header="保存" />
                            <MenuItem Command="{Binding ConnectsModel.ConnectsManage}" CommandParameter="Config" Header="配置" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn MinWidth="60" Binding="{Binding Name, UpdateSourceTrigger=LostFocus}" Header="连接名" />
                        <DataGridTextColumn MinWidth="100" Binding="{Binding Type, UpdateSourceTrigger=LostFocus}" Header="协议类型" IsReadOnly="True" />
                        <DataGridTextColumn MinWidth="100" Binding="{Binding IP_SerialPort, UpdateSourceTrigger=LostFocus}" Header="     IP   &#10;SerialPort" />
                        <DataGridTextColumn MinWidth="40" Binding="{Binding Port, UpdateSourceTrigger=LostFocus}" Header="端口" />
                        <DataGridTextColumn MinWidth="100" Binding="{Binding Comment, UpdateSourceTrigger=LostFocus}" Header="备注" />
                        <DataGridTemplateColumn Header="在线">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Viewbox>
                                        <Ellipse Width="10" Height="10" Fill="{Binding Online, Converter={StaticResource BoolToValueConverter}, Mode=TwoWay, ConverterParameter=Lime, FallbackValue=Gray}" />
                                    </Viewbox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="连接">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Viewbox>
                                        <Ellipse Width="10" Height="10" Fill="{Binding Connected, Converter={StaticResource BoolToValueConverter}, Mode=TwoWay, ConverterParameter=Lime, FallbackValue=Gray}" />
                                    </Viewbox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="读写">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Viewbox>
                                        <Ellipse Width="10" Height="10" Fill="{Binding Successful, Converter={StaticResource BoolToValueConverter}, Mode=TwoWay, ConverterParameter=Lime, FallbackValue=Gray}" />
                                    </Viewbox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn MinWidth="100" Binding="{Binding Params.Prompt}" Header="提示" IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

    </UniformGrid>
</UserControl>