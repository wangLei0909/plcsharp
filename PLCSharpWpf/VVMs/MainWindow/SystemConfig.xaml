<UserControl x:Class="PLCSharp.VVMs.MainWindow.SystemConfig"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PLCSharp.VVMs.MainWindow"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:SystemConfigViewModel}"
             d:DesignHeight="450" d:DesignWidth="800">
    <prism:Dialog.WindowStyle>
        <Style TargetType="Window">
            <Setter Property="SizeToContent" Value="Manual" />
        </Style>
    </prism:Dialog.WindowStyle>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <GroupBox Grid.Column="0" Header="功能管理">
            <!--  功能管理  -->
            <ListBox Width="310" Height="500"
                     HorizontalAlignment="Left" VerticalAlignment="Top"
                     ItemsSource="{Binding Navigate.DialogListShow}"
                     SelectedItem="{Binding Navigate.DialogTarget, Mode=TwoWay}">
                <ListBox.Template>
                    <ControlTemplate TargetType="{x:Type ListBox}">
                        <StackPanel IsItemsHost="True" />
                    </ControlTemplate>
                </ListBox.Template>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Button Width="300" Height="30" Background="Transparent" Command="{Binding Open}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Viewbox>
                                    <TextBlock Text="{Binding IconKind}" FontFamily="{StaticResource iconfont}" />
                                </Viewbox>
                                <TextBlock Grid.Column="1" Text="{Binding DisplayName}" />
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>
        <!--  右侧内容：环境变量管理  -->
        <GroupBox Grid.Column="1" Header="环境变量管理">
            <Grid Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  表格  -->
                <DataGrid Grid.Row="1"
                          Margin="0,5,0,0"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          CanUserDeleteRows="False" CanUserSortColumns="False"
                          ItemsSource="{Binding EnvironmentVariables}"
                          SelectedItem="{Binding SelectedEnvironmentVariable}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          Unloaded="DataGrid_Unloaded">
                    <DataGrid.ContextMenu>
                        <ContextMenu IsEnabled="True" StaysOpen="False">
                            <MenuItem Command="{Binding AddEnvironmentVariable}" Header="新增" />
                            <MenuItem Command="{Binding DeleteEnvironmentVariable}" Header="删除" />
                            <Separator />
                            <MenuItem Command="{Binding Save}" Header="保存" />
                            <Separator />
                            <MenuItem Command="{Binding BrowsePath}" Header="浏览..." />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn MinWidth="120" Binding="{Binding Name, UpdateSourceTrigger=LostFocus}" Header="变量名" />
                        <DataGridTextColumn MinWidth="300" Binding="{Binding Value, UpdateSourceTrigger=LostFocus}" Header="（路径）" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Column="2" Header="状态启用">
            <StackPanel>
                <CheckBox Content="Clearing" IsChecked="{Binding GlobalModel.ModeState.StateConfig.Clearing}" />
                <CheckBox Content="Starting" IsChecked="{Binding GlobalModel.ModeState.StateConfig.Starting}" />
                <CheckBox Content="Suspended" IsChecked="{Binding GlobalModel.ModeState.StateConfig.Suspended}" />
                <CheckBox Content="Stopping" IsChecked="{Binding GlobalModel.ModeState.StateConfig.Stopping}" />
                <CheckBox Content="Aborting" IsChecked="{Binding GlobalModel.ModeState.StateConfig.Aborting}" />
                <CheckBox Content="Holding" IsChecked="{Binding GlobalModel.ModeState.StateConfig.Holding}" />
                <CheckBox Content="UnHolding" IsChecked="{Binding GlobalModel.ModeState.StateConfig.UnHolding}" />
                <CheckBox Content="Suspending" IsChecked="{Binding GlobalModel.ModeState.StateConfig.Suspending}" />
                <CheckBox Content="Resetting" IsChecked="{Binding GlobalModel.ModeState.StateConfig.Resetting}" />
                <CheckBox Content="Completing" IsChecked="{Binding GlobalModel.ModeState.StateConfig.Completing}" />
                <CheckBox Content="Complete" IsChecked="{Binding GlobalModel.ModeState.StateConfig.Complete}" />

            </StackPanel>
        </GroupBox>
        <GroupBox Grid.Row="1" Header="硬件配置导入导出">
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                <Button Width="120" Height="30" Margin="20,5"
                        Command="{Binding ExportHardwareConfig}"
                        Content="导出硬件配置" />
                <Button Width="120" Height="30" Margin="20,5"
                        Command="{Binding ImportHardwareConfig}"
                        Content="导入硬件配置" />
            </StackPanel>
        </GroupBox>
    </Grid>
</UserControl>
