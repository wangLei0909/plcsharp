 //视觉功能
 case 0:
     CurrVF = globalModel.GetVisionFunction("视觉功能名");//如果前面已经获取，这里可以省略
     CurrVF.Flow.Reset();
     flow.Step++;

     break;

 case 1:
     if (CurrVF.RunAll(CurrVF.Flow))
     {
         flow.Step++;
     }
     else if (flow.CheckStepTime(3))
     {
         flow.Step--;
         throw new Exception("视觉功能超时!");
     }
     break;
