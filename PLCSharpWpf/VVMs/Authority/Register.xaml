<UserControl x:Class="PLCSharp.VVMs.Authority.Register"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PLCSharp.VVMs.Authority"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:myControl="clr-namespace:PLCSharp.Core.UserControls"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:RegisterViewModel}"
             Width="400" Height="200">
    <UserControl.Resources>
        <ObjectDataProvider x:Key="Authority" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="local:Authority" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>
    <Grid>
        <Grid Grid.Row="1">

            <Grid Width="300" Height="200">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Text="用户：" HorizontalAlignment="Left" VerticalAlignment="Center" />
                    <TextBox Width="100" Text="{Binding Model.RegisterUser.Name}" />
                    <TextBlock Text="权限：" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <ComboBox Width="100" Margin="10,0,0,0"
                              HorizontalAlignment="Left" VerticalAlignment="Center"
                              ItemsSource="{Binding Source={StaticResource Authority}}"
                              SelectedValue="{Binding Model.RegisterUser.Authority}" />
                </StackPanel>
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Text="密码：" HorizontalAlignment="Left" VerticalAlignment="Center" />
                    <myControl:PasswordBoxNew Width="250" Text="{Binding Model.Password}" />

                </StackPanel>
                <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Text="确认：" HorizontalAlignment="Left" VerticalAlignment="Center" />
                    <myControl:PasswordBoxNew Width="250" Text="{Binding Model.PasswordAct}" />

                </StackPanel>
                <TextBlock Grid.Row="3"
                           d:Text="两次输入不一致"
                           Text="{Binding Model.PasswordMsg}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="Red" />
                <StackPanel Grid.Row="4" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                    <Button Margin="10,0" Command="{Binding Model.Register}" Content="注册" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
