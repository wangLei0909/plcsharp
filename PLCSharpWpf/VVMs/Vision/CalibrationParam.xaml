<UserControl x:Class="PLCSharp.VVMs.Vision.CalibrationParam"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PLCSharp.VVMs.Vision"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:VisionConfigViewModel}"
             Width="200" Height="100"
             Background="AliceBlue">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <UniformGrid Grid.Row="0" Margin="5" Columns="4">


            <TextBlock Height="30" Padding="7" Text="行基准：" TextAlignment="Center" />
            <TextBox Height="30" Text="{Binding RowBase}" />
            <TextBlock Height="30" Padding="7" Text="列基准：" TextAlignment="Center" />
            <TextBox Height="30" Text="{Binding ColBase}" />
            <TextBlock Height="30" Padding="7" Text="间距：" TextAlignment="Center" />
            <TextBox Height="30" Text="{Binding RowColDis}" />
        </UniformGrid>

    </Grid>
</UserControl>
