<UserControl x:Class="PLCSharp.VVMs.Vision.Camera.CameraConfig"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:camera="clr-namespace:PLCSharp.VVMs.Vision.Camera"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:PLCSharp.Core.UserControls"
             xmlns:local="clr-namespace:PLCSharp.VVMs.Vision.Camera"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" d:Background="AliceBlue"
             d:DataContext="{d:DesignInstance Type=local:CameraConfigViewModel}"
             d:DesignHeight="450" d:DesignWidth="1000"
             MinWidth="800" MinHeight="400">
    <prism:Dialog.WindowStyle>
        <Style TargetType="Window">

            <Setter Property="SizeToContent" Value="Manual" />
        </Style>
    </prism:Dialog.WindowStyle>
    <UserControl.Resources>
        <ObjectDataProvider x:Key="TriggerSource" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="camera:TriggerMethod" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>
    <DockPanel LastChildFill="True">
        <controls:ImageEdit MinWidth="600" ImageSource="{Binding ImgSrc}" />
        <StackPanel DockPanel.Dock="Right">
            <StackPanel Orientation="Horizontal">
                <TextBlock Margin="5,0,0,0" Text="曝光时间:" />
                <Slider Width="150" Maximum="{Binding Camera.Params.MaxExposureTime}" Minimum="{Binding Camera.Params.MinExposureTime}" Value="{Binding Camera.Params.ExposureTime}" />
                <TextBox Width="40" Margin="5,0" Text="{Binding Camera.Params.ExposureTime}" />


            </StackPanel>
            <StackPanel Orientation="Horizontal">


                <Button Width="60" Margin="5,0"
                        Command="{Binding CameraCommand}"
                        CommandParameter="Trig" Content="拍照" />
                <Button Width="60" Margin="5,0"
                        Command="{Binding CameraCommand}"
                        CommandParameter="Continuous" Content="实时" />
                <Button Width="60" Margin="5,0" Command="{Binding StopContinuous}" Content="停止实时" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Margin="5,0,0,0" Text="触发源:" />

                <ComboBox Width="100" Margin="10,0" ItemsSource="{Binding Source={StaticResource TriggerSource}}" SelectedItem="{Binding Camera.Params.TriggerSource}" />
            </StackPanel>
        </StackPanel>
    </DockPanel>
</UserControl>
