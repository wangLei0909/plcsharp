<UserControl x:Class="PLCSharp.VVMs.Vision.Visions"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:PLCSharp.Core.UserControls"
             xmlns:local="clr-namespace:PLCSharp.VVMs.Vision"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:VisionsViewModel}"
             d:DesignHeight="450" d:DesignWidth="800">
    <prism:Dialog.WindowStyle>
        <Style TargetType="Window">
            <Setter Property="SizeToContent" Value="Manual" />
        </Style>
    </prism:Dialog.WindowStyle>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>
        <GroupBox Header="相机">
            <Grid>
                <DataGrid Width="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualWidth}"
                          Height="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualHeight}"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          ItemsSource="{Binding VisionsModel.Cameras}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          SelectedItem="{Binding VisionsModel.SelectedCamera}"
                          Unloaded="DataGrid_Unloaded">
                    <DataGrid.ItemContainerStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Prompt}" Value="已修改，请保存">
                                    <Setter Property="Foreground" Value="Red" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Prompt}" Value="">
                                    <Setter Property="Foreground" Value="Black" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.ItemContainerStyle>
                    <DataGrid.ContextMenu>
                        <ContextMenu IsEnabled="True" StaysOpen="False">
                            <MenuItem Command="{Binding VisionsModel.CamreraManage}" CommandParameter="Remove" Header="删除" />
                            <MenuItem Command="{Binding VisionsModel.CamreraManage}" CommandParameter="Save" Header="保存" />
                            <MenuItem Command="{Binding VisionsModel.CamreraManage}" CommandParameter="Config" Header="配置" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn MinWidth="100" Binding="{Binding Name, UpdateSourceTrigger=LostFocus}" Header="相机名" IsReadOnly="True" />
                        <DataGridTextColumn MinWidth="200" Binding="{Binding Comment, UpdateSourceTrigger=LostFocus}" Header="备注" />
                        <DataGridTextColumn MinWidth="100" Binding="{Binding Prompt}" Header="提示" IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="1" Header="功能列表">
            <Grid>
                <DataGrid Width="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualWidth}"
                          Height="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualHeight}"
                          HorizontalAlignment="Left" VerticalAlignment="Center"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          CanUserDeleteRows="False" CanUserSortColumns="False"
                          ItemsSource="{Binding VisionsModel.VisionFunctions}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          SelectedItem="{Binding VisionsModel.SelectedVisionFunction}"
                          Unloaded="DataGrid_Unloaded">
                    <DataGrid.ItemContainerStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Prompt}" Value="已修改，请保存">
                                    <Setter Property="Foreground" Value="Red" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Prompt}" Value="">
                                    <Setter Property="Foreground" Value="Black" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.ItemContainerStyle>
                    <DataGrid.ContextMenu>
                        <ContextMenu IsEnabled="True" StaysOpen="False">
                            <MenuItem Command="{Binding VisionsModel.Manage}" CommandParameter="New" Header="新增" />
                            <MenuItem Command="{Binding VisionsModel.Manage}" CommandParameter="Remove" Header="删除" />
                            <MenuItem Command="{Binding VisionsModel.Manage}" CommandParameter="Save" Header="保存" />
                            <MenuItem Command="{Binding VisionsModel.Manage}" CommandParameter="Config" Header="配置" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn MinWidth="60" Binding="{Binding Name, UpdateSourceTrigger=LostFocus}" Header="名称" />
                        <DataGridTextColumn MinWidth="50" Binding="{Binding ControlName, UpdateSourceTrigger=LostFocus}" Header="首页控件" />
                        <DataGridTextColumn MinWidth="200" Binding="{Binding Comment, UpdateSourceTrigger=LostFocus}" Header="备注" />
                        <DataGridTextColumn MinWidth="100" Binding="{Binding Prompt}" Header="提示" IsReadOnly="True" />
                    </DataGrid.Columns>

                </DataGrid>
            </Grid>
        </GroupBox>
        <Grid Grid.RowSpan="2" Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="100" />
            </Grid.RowDefinitions>
            <controls:ImageEdit MinWidth="600" ImageSource="{Binding ImgSrc}" />
            <StackPanel Grid.Row="1">
                <StackPanel Margin="5" Orientation="Horizontal">
                    <TextBlock Margin="5,0,0,0" Text="相机:" />
                    <ComboBox Width="120" Margin="10,0"
                              DisplayMemberPath="Name"
                              ItemsSource="{Binding VisionsModel.CamerasAll}"
                              SelectedItem="{Binding Camera}" />
                    <Button Width="60" Command="{Binding SearchCameras}" Content="搜索相机" />
                    <Button Width="60" Margin="5,0" Command="{Binding AddCameras}" Content="加入左侧列表" />
                </StackPanel>
                <StackPanel Margin="5" Orientation="Horizontal">
                    <Button Width="60" Margin="5,0"
                            Command="{Binding CameraCommand}"
                            CommandParameter="Trig" Content="拍照" />
                    <Button Width="60" Margin="5,0"
                            Command="{Binding CameraCommand}"
                            CommandParameter="Continuous" Content="实时" />
                    <Button Width="60" Margin="5,0" Command="{Binding StopContinuous}" Content="停止实时" />
                </StackPanel>
                <StackPanel Margin="5" Orientation="Horizontal">
                    <TextBlock Margin="5,0,0,0" Text="曝光时间:" />
                    <Slider Width="250" Maximum="{Binding Camera.Params.MaxExposureTime}" Minimum="{Binding Camera.Params.MinExposureTime}" Value="{Binding Camera.Params.ExposureTime}" />
                    <TextBox Width="40" Margin="5,0" Text="{Binding Camera.Params.ExposureTime}" />


                </StackPanel>


            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
