<UserControl x:Class="PLCSharp.VVMs.Vision.VisionFlowHandler.Access.ImageToHomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PLCSharp.VVMs.Vision.VisionFlowHandler"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vision="clr-namespace:PLCSharp.VVMs.Vision"
             mc:Ignorable="d" d:Background="AliceBlue"
             d:DataContext="{d:DesignInstance Type=vision:VisionConfigViewModel}"
             d:DesignHeight="150" d:DesignWidth="300">
    <StackPanel>
        <TextBlock Text="{Binding Path=SelectVisionFlow.StringParams[CustomControlName]}" />
        <ComboBox DisplayMemberPath="Name" ItemsSource="{Binding Path=GlobalModel.CustomControls}" SelectedValue="{Binding Path=SelectVisionFlow.StringParams[CustomControlName], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Name" />
    </StackPanel>
</UserControl>
