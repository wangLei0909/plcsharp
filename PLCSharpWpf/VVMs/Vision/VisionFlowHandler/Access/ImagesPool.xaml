<UserControl x:Class="PLCSharp.VVMs.Vision.VisionFlowHandler.Access.ImagesPool"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PLCSharp.VVMs.Vision.VisionFlowHandler"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vision="clr-namespace:PLCSharp.VVMs.Vision"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vision:VisionConfigViewModel}"
             d:DesignHeight="150" d:DesignWidth="300">
    <StackPanel>
        <TextBlock Text="{Binding Path=SelectVisionFlow.StringParams[Image]}" />

        <ComboBox DisplayMemberPath="Name" ItemsSource="{Binding VisionsModel.ImageDatas}" SelectedItem="{Binding SelectImageData}" />
    </StackPanel>
</UserControl>
