<UserControl x:Class="PLCSharp.VVMs.Vision.VisionFlowHandler.Access.ImageFromCamera"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PLCSharp.VVMs.Vision.VisionFlowHandler"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vision="clr-namespace:PLCSharp.VVMs.Vision"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vision:VisionConfigViewModel}"
             d:DesignHeight="150" d:DesignWidth="300">
    <StackPanel>

        <TextBlock Text="{Binding Path=SelectVisionFlow.StringParams[Camera]}" TextWrapping="Wrap" />
        <ComboBox DisplayMemberPath="Name" ItemsSource="{Binding VisionsModel.Cameras}" SelectedItem="{Binding SelectedCamera}" TextSearch.TextPath="Name" />
        <StackPanel Orientation="Horizontal">
            <TextBlock Margin="5" Text="曝光时间:" />
            <TextBox Width="100" Margin="5" Text="{Binding Path=SelectVisionFlow.DoubleParams[ExposureTime]}" />
            <TextBlock Margin="5" Text="μs" />

        </StackPanel>

    </StackPanel>
</UserControl>
