<UserControl x:Class="PLCSharp.VVMs.Vision.VisionFlowHandler.Algorithm.CaliperEdgeFind"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PLCSharp.VVMs.Vision.VisionFlowHandler"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vision="clr-namespace:PLCSharp.VVMs.Vision"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vision:VisionConfigViewModel}"
             d:DesignHeight="350" d:DesignWidth="300">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <GroupBox Header="直线">
                <StackPanel>
                    <Button Height="25" Margin="5" Command="{Binding DrawFindEdgeROI}" Content="画线" />
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock Margin="5,0" Text="起点X" />
                        <TextBox Grid.Column="1" Text="{Binding SelectVisionFlow.DoubleParams[LineStartX], UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="1" Margin="5,0" Text="起点Y" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SelectVisionFlow.DoubleParams[LineStartY], UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Margin="5,0" Text="终点X" />
                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding SelectVisionFlow.DoubleParams[LineEndX], UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Margin="5,0" Text="终点Y" />
                        <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding SelectVisionFlow.DoubleParams[LineEndY], UpdateSourceTrigger=LostFocus}" />
                    </Grid>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="卡尺参数">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="边缘阈值" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" Text="{Binding SelectVisionFlow.IntParams[Threshold], Mode=TwoWay, TargetNullValue=30}" />

                    <TextBlock Grid.Row="1" Text="卡尺长度" VerticalAlignment="Center" ToolTip="扫描线长度（像素）" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SelectVisionFlow.IntParams[CaliperLength], Mode=TwoWay, TargetNullValue=100, UpdateSourceTrigger=LostFocus}" />

                    <TextBlock Grid.Row="2" Text="卡尺数量" VerticalAlignment="Center" ToolTip="扫描线数量" />
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SelectVisionFlow.IntParams[NumCalipers], Mode=TwoWay, TargetNullValue=10, UpdateSourceTrigger=LostFocus}" />

                    <TextBlock Grid.Row="3" Text="方向" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="3" Grid.Column="1" SelectedIndex="{Binding SelectVisionFlow.IntParams[Direction], Mode=TwoWay}">
                        <ComboBoxItem Content="黑→白" />
                        <ComboBoxItem Content="白→黑" />
                        <ComboBoxItem Content="双向" />
                    </ComboBox>

                    <TextBlock Grid.Row="4" Text="边缘选择" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="4" Grid.Column="1" SelectedIndex="{Binding SelectVisionFlow.IntParams[EdgeSelector], Mode=TwoWay}">
                        <ComboBoxItem Content="第一个" />
                        <ComboBoxItem Content="最后一个" />
                    </ComboBox>

                    <TextBlock Grid.Row="5" Text="最小分数%" VerticalAlignment="Center" />
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding SelectVisionFlow.IntParams[MinScore], Mode=TwoWay, TargetNullValue=10}" />

                    <TextBlock Grid.Row="6" Text="RANSAC阈值" VerticalAlignment="Center" />
                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding SelectVisionFlow.DoubleParams[RansacTh], Mode=TwoWay, TargetNullValue=5, UpdateSourceTrigger=LostFocus}" />

                    <TextBlock Grid.Row="7" Text="结果变量" VerticalAlignment="Center" />
                    <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding SelectVisionFlow.StringParams[EdgeName], Mode=TwoWay, TargetNullValue=卡尺寻边_Edge}" />
                </Grid>
            </GroupBox>
            <GroupBox Header="模板">
                <StackPanel>
                    <Button Height="25" Margin="5" Command="{Binding ComputeEdgeTemplate}" Content="计算模板位置" />
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Text="模板起点X" VerticalAlignment="Center" />
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding SelectVisionFlow.DoubleParams[TemplateLineStartX], TargetNullValue=—}"
                                 IsReadOnly="True" Background="#FFF0F0F0" />
                        <TextBlock Grid.Row="1" Text="模板起点Y" VerticalAlignment="Center" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding SelectVisionFlow.DoubleParams[TemplateLineStartY], TargetNullValue=—}"
                                 IsReadOnly="True" Background="#FFF0F0F0" />
                        <TextBlock Grid.Row="2" Text="模板终点X" VerticalAlignment="Center" />
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding SelectVisionFlow.DoubleParams[TemplateLineEndX], TargetNullValue=—}"
                                 IsReadOnly="True" Background="#FFF0F0F0" />
                        <TextBlock Grid.Row="3" Text="模板终点Y" VerticalAlignment="Center" />
                        <TextBox Grid.Row="3" Grid.Column="1"
                                 Text="{Binding SelectVisionFlow.DoubleParams[TemplateLineEndY], TargetNullValue=—}"
                                 IsReadOnly="True" Background="#FFF0F0F0" />
                        <TextBlock Grid.Row="4" Text="模板角度" VerticalAlignment="Center" />
                        <TextBox Grid.Row="4" Grid.Column="1"
                                 Text="{Binding SelectVisionFlow.DoubleParams[TemplateLineAngle], TargetNullValue=—}"
                                 IsReadOnly="True" Background="#FFF0F0F0" />
                    </Grid>
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="偏移变量" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding SelectVisionFlow.StringParams[LineOffsetVar], Mode=TwoWay, TargetNullValue=找线_Offset}" />
                    </Grid>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
