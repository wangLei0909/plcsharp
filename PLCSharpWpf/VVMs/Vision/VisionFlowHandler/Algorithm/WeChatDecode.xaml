<UserControl x:Class="PLCSharp.VVMs.Vision.VisionFlowHandler.Algorithm.WeChatDecode"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PLCSharp.VVMs.Vision.VisionFlowHandler"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vision="clr-namespace:PLCSharp.VVMs.Vision"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vision:VisionConfigViewModel}"
             d:DesignHeight="400" d:DesignWidth="300">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- 解码参数 -->
            <GroupBox Header="解码参数">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="镜像" VerticalAlignment="Center" ToolTip="对图像做水平镜像翻转" />
                    <CheckBox Grid.Column="1" Margin="5,0"
                              IsChecked="{Binding SelectVisionFlow.BoolParams[EnableMirror], Mode=TwoWay}" />
                </Grid>
            </GroupBox>

            <!-- 变量设置 -->
            <GroupBox Header="变量设置">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="结果变量名" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding SelectVisionFlow.StringParams[ResultVarName], Mode=TwoWay, TargetNullValue=微信解码_Result, UpdateSourceTrigger=LostFocus}" />
                </Grid>
            </GroupBox>

            <!-- 解码结果 -->
            <GroupBox Header="解码结果">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="解码状态" VerticalAlignment="Center" ToolTip="1=成功，0=未找到" />
                    <TextBox Grid.Column="1"
                             Text="{Binding SelectedVisionFunction.Params.ResultDoubles[DecodeSuccess], Mode=OneWay}"
                             IsReadOnly="True" Background="#FFF0F0F0" />

                    <TextBlock Grid.Row="1" Text="找到码数" VerticalAlignment="Center" />
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{Binding SelectedVisionFunction.Params.ResultDoubles[DecodeCount], Mode=OneWay}"
                             IsReadOnly="True" Background="#FFF0F0F0" />

                    <TextBlock Grid.Row="2" Text="解码内容" VerticalAlignment="Center" />
                    <TextBox Grid.Row="2" Grid.Column="1"
                             Text="{Binding SelectVisionFlow.StringParams[DecodeResult], Mode=OneWay}"
                             IsReadOnly="True" Background="#FFF0F0F0"
                             TextWrapping="Wrap" MinHeight="60" />
                </Grid>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
