<UserControl x:Class="PLCSharp.VVMs.Vision.VisionFlowHandler.Algorithm.CaliperFindCircle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PLCSharp.VVMs.Vision.VisionFlowHandler"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vision="clr-namespace:PLCSharp.VVMs.Vision"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vision:VisionConfigViewModel}"
             d:DesignHeight="350" d:DesignWidth="300">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <GroupBox Header="圆形 ROI">
                <StackPanel>
                    <Button Height="25" Margin="5" Command="{Binding DrawFindCircleROI}" Content="画圆" />
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock Margin="5,0" Text="圆心X" />
                        <TextBox Grid.Column="1" Text="{Binding SelectVisionFlow.DoubleParams[CircleCenterX], UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Margin="5,0" Text="圆心Y" />
                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding SelectVisionFlow.DoubleParams[CircleCenterY], UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Grid.Row="1" Margin="5,0" Text="半径" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SelectVisionFlow.DoubleParams[CircleRadius], UpdateSourceTrigger=LostFocus}" />
                    </Grid>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="卡尺参数">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="边缘阈值" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" Text="{Binding SelectVisionFlow.IntParams[Threshold], Mode=TwoWay, TargetNullValue=30}" />


                    <TextBlock Grid.Row="2" Text="卡尺长度" VerticalAlignment="Center" ToolTip="径向扫描线长度（像素）" />
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SelectVisionFlow.IntParams[CaliperLength], Mode=TwoWay, TargetNullValue=100, UpdateSourceTrigger=LostFocus}" />

                    <TextBlock Grid.Row="3" Text="卡尺数量" VerticalAlignment="Center" ToolTip="圆周上均布的扫描线数量" />
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SelectVisionFlow.IntParams[NumCalipers], Mode=TwoWay, TargetNullValue=50, UpdateSourceTrigger=LostFocus}" />

                    <TextBlock Grid.Row="4" Text="方向" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="4" Grid.Column="1" SelectedIndex="{Binding SelectVisionFlow.IntParams[Direction], Mode=TwoWay}">
                        <ComboBoxItem Content="黑→白" />
                        <ComboBoxItem Content="白→黑" />
                        <ComboBoxItem Content="双向" />
                    </ComboBox>

                    <TextBlock Grid.Row="5" Text="卡尺方向" VerticalAlignment="Center" ToolTip="扫描线相对于圆周的偏移方向" />
                    <ComboBox Grid.Row="5" Grid.Column="1" SelectedIndex="{Binding SelectVisionFlow.IntParams[CaliperDirection], Mode=TwoWay}">
                        <ComboBoxItem Content="从内向外" />
                        <ComboBoxItem Content="从外向内" />
                    </ComboBox>

                    <TextBlock Grid.Row="6" Text="边缘选择" VerticalAlignment="Center" ToolTip="选择第一个还是最后一个符合方向的边缘" />
                    <ComboBox Grid.Row="6" Grid.Column="1" SelectedIndex="{Binding SelectVisionFlow.IntParams[EdgeSelector], Mode=TwoWay}">
                        <ComboBoxItem Content="第一个" />
                        <ComboBoxItem Content="最后一个" />
                    </ComboBox>

                    <TextBlock Grid.Row="7" Text="最小分数%" VerticalAlignment="Center" />
                    <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding SelectVisionFlow.IntParams[MinScore], Mode=TwoWay, TargetNullValue=10}" />

                    <TextBlock Grid.Row="8" Text="RANSAC阈值" VerticalAlignment="Center" ToolTip="点到拟合圆的距离阈值（像素），用于区分内点和离群点" />
                    <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding SelectVisionFlow.DoubleParams[RansacTh], Mode=TwoWay, TargetNullValue=5, UpdateSourceTrigger=LostFocus}" />

                    <TextBlock Grid.Row="9" Text="最小内点数" VerticalAlignment="Center" ToolTip="RANSAC 拟合的内点数量下限" />
                    <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding SelectVisionFlow.IntParams[MinInliers], Mode=TwoWay, TargetNullValue=10, UpdateSourceTrigger=LostFocus}" />

                    <TextBlock Grid.Row="10" Text="结果变量" VerticalAlignment="Center" ToolTip="结果保存到此 Circle 类型变量" />
                    <TextBox Grid.Row="10" Grid.Column="1" Text="{Binding SelectVisionFlow.StringParams[CircleResultVar], Mode=TwoWay, TargetNullValue=卡尺找圆_Circle}" />

                    <TextBlock Grid.Row="11" Text="内点数" VerticalAlignment="Center" />
                    <TextBox Grid.Row="11" Grid.Column="1"
                             Text="{Binding SelectedVisionFunction.Params.ResultDoubles[InlierCount], Mode=OneWay}"
                             IsReadOnly="True" Background="#FFF0F0F0" />
                </Grid>
            </GroupBox>
            <GroupBox Header="模板">
                <StackPanel>
                    <Button Height="25" Margin="5" Command="{Binding ComputeCircleTemplate}" Content="计算模板位置" />
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Text="模板X" VerticalAlignment="Center" />
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding SelectVisionFlow.DoubleParams[TemplateCircleCX], TargetNullValue=—}"
                                 IsReadOnly="True" Background="#FFF0F0F0" />
                        <TextBlock Grid.Row="1" Text="模板Y" VerticalAlignment="Center" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding SelectVisionFlow.DoubleParams[TemplateCircleCY], TargetNullValue=—}"
                                 IsReadOnly="True" Background="#FFF0F0F0" />
                        <TextBlock Grid.Row="2" Text="模板半径" VerticalAlignment="Center" />
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding SelectVisionFlow.DoubleParams[TemplateCircleR], TargetNullValue=—}"
                                 IsReadOnly="True" Background="#FFF0F0F0" />
                    </Grid>
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="偏移变量" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding SelectVisionFlow.StringParams[CircleOffsetVar], Mode=TwoWay, TargetNullValue=找圆_Offset}" />
                    </Grid>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
