<UserControl x:Class="PLCSharp.VVMs.Vision.VisionFlowHandler.Processing.Threshold"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PLCSharp.VVMs.Vision.VisionFlowHandler"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vision="clr-namespace:PLCSharp.VVMs.Vision"
             mc:Ignorable="d" d:Background="AliceBlue"
             d:DataContext="{d:DesignInstance Type=vision:VisionConfigViewModel}"
             d:DesignHeight="450" d:DesignWidth="400">
    <Grid>
        <StackPanel>
            <StackPanel Height="20" Orientation="Horizontal">
                <TextBlock Text="ThresholdType：" />
                <ComboBox Width="80" SelectedIndex="{Binding SelectVisionFlow.IntParams[ThresholdType]}">
                    <ComboBoxItem Content="Binary" />
                    <ComboBoxItem Content="BinaryInv" />
                    <ComboBoxItem Content="Tozero" />
                    <ComboBoxItem Content="TozeroInv" />
                    <ComboBoxItem Content="Trunc" />
                </ComboBox>


            </StackPanel>
            <StackPanel Height="20" Orientation="Horizontal" />

            <StackPanel Height="20" Orientation="Horizontal">
                <CheckBox Margin="10,0" VerticalAlignment="Center" Content="Otsu" IsChecked="{Binding SelectVisionFlow.BoolParams[IsOtsu]}" />
                <CheckBox Margin="10,0" VerticalAlignment="Center" Content="Triangle" IsChecked="{Binding SelectVisionFlow.BoolParams[IsTriangle]}" />
            </StackPanel>
            <StackPanel Height="20" Orientation="Horizontal" />

            <StackPanel Height="20" Orientation="Horizontal">
                <TextBlock Margin="5,0" Text="Threshold：" />
                <Slider Width="120"
                        IsMoveToPointEnabled="True" Maximum="254" Minimum="1"
                        Value="{Binding SelectVisionFlow.IntParams[Threshold]}" />
            </StackPanel>
            <StackPanel Height="20" Orientation="Horizontal" />
            <StackPanel Orientation="Horizontal">

                <TextBlock Margin="5,0" Text="MaxValue：" />
                <Slider Width="120"
                        IsMoveToPointEnabled="True" Maximum="254" Minimum="1"
                        Value="{Binding SelectVisionFlow.IntParams[MaxValue]}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
