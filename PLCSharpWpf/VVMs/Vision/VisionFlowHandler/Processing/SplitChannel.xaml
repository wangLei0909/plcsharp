<UserControl x:Class="PLCSharp.VVMs.Vision.VisionFlowHandler.Processing.SplitChannel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PLCSharp.VVMs.Vision.VisionFlowHandler"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vision="clr-namespace:PLCSharp.VVMs.Vision"
             mc:Ignorable="d" d:Background="AliceBlue"
             d:DataContext="{d:DesignInstance Type=vision:VisionConfigViewModel}"
             d:DesignHeight="150" d:DesignWidth="300">
    <StackPanel>
        <TextBlock Margin="5,5,5,0" Text="选择通道：" />
        <ComboBox Margin="5,2,5,5" SelectedIndex="{Binding SelectVisionFlow.IntParams[ChannelIndex]}">
            <ComboBoxItem Content="通道 0 (B/GRAY)" />
            <ComboBoxItem Content="通道 1 (G)" />
            <ComboBoxItem Content="通道 2 (R)" />
        </ComboBox>
    </StackPanel>
</UserControl>
