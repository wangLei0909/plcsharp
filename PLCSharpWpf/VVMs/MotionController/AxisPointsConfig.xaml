<UserControl x:Class="PLCSharp.VVMs.MotionController.AxisPointsConfig"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PLCSharp.VVMs.MotionController"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:Background="AliceBlue"
             d:DataContext="{d:DesignInstance Type=local:ControllersModel}"
             d:DesignHeight="800" d:DesignWidth="1000"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3*" />
            <RowDefinition Height="1*" />

        </Grid.RowDefinitions>
        <Grid Tag="数据">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />

            </Grid.ColumnDefinitions>
            <Grid Grid.ColumnSpan="2" Tag="表">
                <DataGrid Width="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualWidth}"
                          Height="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualHeight}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserSortColumns="False"
                          ItemsSource="{Binding AxisPoints}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          SelectedItem="{Binding SelectedAxisPoint}"
                          Unloaded="DataGrid_Unloaded">
                    <DataGrid.ContextMenu>
                        <ContextMenu IsEnabled="True" StaysOpen="False">
                            <MenuItem Command="{Binding AxisPointsManage}" CommandParameter="New" Header="新增" />
                            <MenuItem Command="{Binding AxisPointsManage}" CommandParameter="Remove" Header="删除" />
                            <MenuItem Command="{Binding AxisPointsManage}" CommandParameter="Save" Header="保存" />
                            <MenuItem Command="{Binding AxisPointsManage}" CommandParameter="Go" Header="Go" />
                            <MenuItem Command="{Binding AxisPointsManage}" CommandParameter="Jump" Header="Jump" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>

                        <DataGridTextColumn MinWidth="100" Binding="{Binding Name, UpdateSourceTrigger=LostFocus}" Header="名称" />
                        <DataGridTextColumn MinWidth="100" Binding="{Binding X, UpdateSourceTrigger=LostFocus}" Header="X" />
                        <DataGridTextColumn MinWidth="100" Binding="{Binding Y, UpdateSourceTrigger=LostFocus}" Header="Y" />
                        <DataGridTextColumn MinWidth="100" Binding="{Binding Z, UpdateSourceTrigger=LostFocus}" Header="Z" />
                        <DataGridTextColumn MinWidth="100" Binding="{Binding U, UpdateSourceTrigger=LostFocus}" Header="U" />

                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
            <Grid Grid.Column="2" Grid.ColumnSpan="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                <Grid MinHeight="500" Tag="设置">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*" />
                        <RowDefinition Height="1*" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>
                    <GroupBox Header="速率">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="2*" />
                                <RowDefinition Height="2*" />
                                <RowDefinition Height="2*" />
                                <RowDefinition Height="2*" />
                                <RowDefinition Height="3*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="5*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <!--  X轴  -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="X轴：" />
                            <ComboBox Grid.Row="0" Grid.Column="1" DisplayMemberPath="Name" ItemsSource="{Binding Axes}" SelectedItem="{Binding SelectedAxisPoint.AxisX, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="速率:" />
                            <Slider Grid.Row="0" Grid.Column="3" Maximum="100" Minimum="1" SmallChange="1" Value="{Binding SelectedAxisPoint.XRate}" />
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding SelectedAxisPoint.XRate, StringFormat={}{0:F0}}" />
                            <!--  Y轴  -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Y轴：" />
                            <ComboBox Grid.Row="1" Grid.Column="1" DisplayMemberPath="Name" ItemsSource="{Binding Axes}" SelectedItem="{Binding SelectedAxisPoint.AxisY, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="1" Grid.Column="2" Text="速率:" />
                            <Slider Grid.Row="1" Grid.Column="3" Maximum="100" Minimum="1" SmallChange="1" Value="{Binding SelectedAxisPoint.YRate}" />
                            <TextBlock Grid.Row="1" Grid.Column="4" Text="{Binding SelectedAxisPoint.YRate, StringFormat={}{0:F0}}" />
                            <!--  Z轴  -->

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Z轴：" />
                            <ComboBox Grid.Row="2" Grid.Column="1" DisplayMemberPath="Name" ItemsSource="{Binding Axes}" SelectedItem="{Binding SelectedAxisPoint.AxisZ, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="2" Grid.Column="2" Text="速率:" />
                            <Slider Grid.Row="2" Grid.Column="3" Maximum="100" Minimum="1" SmallChange="1" Value="{Binding SelectedAxisPoint.ZRate}" />
                            <TextBlock Grid.Row="2" Grid.Column="4" Text="{Binding SelectedAxisPoint.ZRate, StringFormat={}{0:F0}}" />
                            <!--  U轴  -->

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="U轴：" />
                            <ComboBox Grid.Row="3" Grid.Column="1" DisplayMemberPath="Name" ItemsSource="{Binding Axes}" SelectedItem="{Binding SelectedAxisPoint.AxisU, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="速率:" />
                            <Slider Grid.Row="3" Grid.Column="3" Maximum="100" Minimum="1" SmallChange="1" Value="{Binding SelectedAxisPoint.URate}" />
                            <TextBlock Grid.Row="3" Grid.Column="4" Text="{Binding SelectedAxisPoint.URate, StringFormat={}{0:F0}}" />
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="总速率:" Margin="0,10" />
                            <Slider Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Margin="10" Maximum="100" Minimum="1" SmallChange="1" Value="{Binding Rate}" />
                            <TextBlock Grid.Row="4" Grid.Column="4" Text="{Binding Rate, StringFormat={}{0:F0}}" Margin="0,10" />
                        </Grid>
                    </GroupBox>

                </Grid>
                <StackPanel Grid.Row="1" VerticalAlignment="Top" Orientation="Horizontal">

                    <TextBlock Text="Z轴安全位：" />
                    <TextBox Width="50" Text="{Binding SelectedAxisPoint.ZSafe}" />
                </StackPanel>
            </Grid>
        </Grid>


        <Grid Grid.Row="1" Tag="操作">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="4*" />
            </Grid.ColumnDefinitions>
            <GroupBox Header="点动">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Row="1" Grid.Column="2" Margin="5,0" Command="{Binding AxisPointCommand}" CommandParameter="X+" Content="X+" />
                    <Button Grid.Row="1" Grid.Column="0" Margin="5,0" Command="{Binding AxisPointCommand}" CommandParameter="X-" Content="X-" />

                    <Button Grid.Row="0" Grid.Column="1" Margin="10,0" Command="{Binding AxisPointCommand}" CommandParameter="Y+" Content="Y+" />
                    <Button Grid.Row="2" Grid.Column="1" Margin="10,0" Command="{Binding AxisPointCommand}" CommandParameter="Y-" Content="Y-" />
                    <Button Grid.Row="2" Grid.Column="2" Width="50" Margin="10,5" Command="{Binding AxisPointCommand}" CommandParameter="Z+" Content="Z+" />
                    <Button Grid.Row="0" Grid.Column="2" Width="50" Margin="10,5" Command="{Binding AxisPointCommand}" CommandParameter="Z-" Content="Z-" />
                    <Button Grid.Row="2" Grid.Column="0" Width="50" Margin="10,5" Command="{Binding AxisPointCommand}" CommandParameter="U+" Content="U+" />
                    <Button Grid.Row="0" Grid.Column="0" Width="50" Margin="10,5" Command="{Binding AxisPointCommand}" CommandParameter="U-" Content="U-" />

                    <Button Grid.Row="1" Grid.Column="1"
                            Margin="3" Padding="15,3"
                            Background="Red"
                            Command="{Binding AxisPointCommand}"
                            CommandParameter="Stop" Content="STOP"
                            FontSize="14" FontWeight="Bold" />
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="当前位置">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />

                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="X轴：" />
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding SelectedAxisPoint.AxisX.CommandPosition}" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Y轴：" />
                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding SelectedAxisPoint.AxisY.CommandPosition}" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Z轴：" />
                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding SelectedAxisPoint.AxisZ.CommandPosition}" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="U轴：" />
                    <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding SelectedAxisPoint.AxisU.CommandPosition}" />
                    <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Command="{Binding AxisPointCommand}" CommandParameter="Save" Content="保存到选中点" />
                </Grid>
            </GroupBox>
            <GroupBox Grid.Column="2" Header="点动距离">
                <UniformGrid Grid.Column="2" Columns="2">
                    <TextBlock Text="寸动距离" Margin="3" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" />
                    <TextBox Height="30" Text="{Binding RelativeDistance}" Margin="3" FontSize="14" FontWeight="Bold" />

                    <Button Width="50" Margin="3" Command="{Binding DistanceSet}" CommandParameter="Jog0.01" Content="0.01" FontSize="14" FontWeight="Bold" />
                    <Button Width="50" Margin="3" Command="{Binding DistanceSet}" CommandParameter="Jog0.1" Content="0.1" FontSize="14" FontWeight="Bold" />
                    <Button Width="50" Margin="3" Command="{Binding DistanceSet}" CommandParameter="Jog1" Content="1" FontSize="14" FontWeight="Bold" />
                    <Button Width="50" Margin="3" Command="{Binding DistanceSet}" CommandParameter="Jog5" Content="5" FontSize="14" FontWeight="Bold" />
                    <Button Width="50" Margin="3" Command="{Binding DistanceSet}" CommandParameter="Jog10" Content="10" FontSize="14" FontWeight="Bold" />
                    <Button Width="50" Margin="3" Command="{Binding DistanceSet}" CommandParameter="Jog20" Content="20" FontSize="14" FontWeight="Bold" />

                </UniformGrid>
            </GroupBox>
        </Grid>

    </Grid>
</UserControl>
