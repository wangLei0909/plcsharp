<UserControl x:Class="PLCSharp.VVMs.MotionController.Controllers"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PLCSharp.VVMs.MotionController"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:ControllersViewModel}"
             d:DesignHeight="450" d:DesignWidth="1000">
    <prism:Dialog.WindowStyle>
        <Style TargetType="Window">
            <Setter Property="SizeToContent" Value="Manual" />
        </Style>
    </prism:Dialog.WindowStyle>
    <UserControl.Resources>
        <ObjectDataProvider x:Key="ControllerType" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="local:ControllerType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>
    <TabControl>
        <TabItem Header="点位配置">
            <ContentControl Grid.Row="1" Grid.RowSpan="2" Grid.Column="0" Content="{Binding ControllerModel.AxisPointsConfig}" />
        </TabItem>
        <TabItem Header="插补配置">
            <ContentControl Grid.Row="1" Grid.RowSpan="2" Grid.Column="0" Content="{Binding ControllerModel.InterpolationConfig}" />
        </TabItem>
        <TabItem Header="控制器与轴">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width=" *" />
                </Grid.ColumnDefinitions>
                <GroupBox Header="控制器">
                    <Grid>
                        <DataGrid Width="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualWidth}"
                                  Height="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualHeight}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  CanUserDeleteRows="False" CanUserSortColumns="False"
                                  ItemsSource="{Binding ControllerModel.Controllers}"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  SelectedItem="{Binding ControllerModel.SelectedController}"
                                  Unloaded="DataGrid_Unloaded">
                            <DataGrid.ContextMenu>
                                <ContextMenu IsEnabled="True" StaysOpen="False">
                                    <MenuItem Command="{Binding ControllerModel.ControllerManage}" CommandParameter="New" Header="新增" />
                                    <MenuItem Command="{Binding ControllerModel.ControllerManage}" CommandParameter="Remove" Header="删除" />
                                    <MenuItem Command="{Binding ControllerModel.ControllerManage}" CommandParameter="Save" Header="保存" />
                                    <MenuItem Command="{Binding ControllerModel.ControllerManage}" CommandParameter="Config" Header="配置" />

                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridComboBoxColumn MinWidth="100" Header="型号" ItemsSource="{Binding Source={StaticResource ControllerType}}" SelectedValueBinding="{Binding Type, UpdateSourceTrigger=PropertyChanged}" />
                                <DataGridTextColumn MinWidth="100" Binding="{Binding ControllerNo}" Header="连接号" IsReadOnly="True" />
                                <DataGridTextColumn MinWidth="100" Binding="{Binding IP, UpdateSourceTrigger=LostFocus}" Header="IP" />
                                <DataGridTextColumn MinWidth="100" Binding="{Binding Comment, UpdateSourceTrigger=LostFocus}" Header="备注" />
                                <DataGridTemplateColumn Header="在线">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Viewbox>
                                                <Ellipse Width="10" Height="10" Fill="{Binding Online, Converter={StaticResource BoolToValueConverter}, Mode=TwoWay, ConverterParameter=Lime, FallbackValue=Gray}" />
                                            </Viewbox>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="连接">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Viewbox>
                                                <Ellipse Width="10" Height="10" Fill="{Binding Connected, Converter={StaticResource BoolToValueConverter}, Mode=TwoWay, ConverterParameter=Lime, FallbackValue=Gray}" />
                                            </Viewbox>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn MinWidth="100" Binding="{Binding Prompt}" Header="提示" IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </GroupBox>
                <GroupBox Grid.Column="1" Header="轴">
                    <Grid>
                        <DataGrid Width="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualWidth}"
                                  Height="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualHeight}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  CanUserDeleteRows="False" CanUserSortColumns="False"
                                  ItemsSource="{Binding ControllerModel.SelectedController.Axes}"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  SelectedItem="{Binding ControllerModel.SelectedAxis}"
                                  Unloaded="DataGrid_Unloaded">
                            <DataGrid.ContextMenu>
                                <ContextMenu IsEnabled="True" StaysOpen="False">
                                    <MenuItem Command="{Binding ControllerModel.AxisManage}" CommandParameter="New" Header="新增" />
                                    <MenuItem Command="{Binding ControllerModel.AxisManage}" CommandParameter="Remove" Header="删除" />
                                    <MenuItem Command="{Binding ControllerModel.AxisManage}" CommandParameter="Save" Header="保存" />

                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn MinWidth="100" Binding="{Binding AxisNo}" Header="轴号" />
                                <DataGridTextColumn MinWidth="100" Binding="{Binding Name, UpdateSourceTrigger=LostFocus}" Header="轴名称" />
                                <DataGridTextColumn MinWidth="200" Binding="{Binding Comment, UpdateSourceTrigger=LostFocus}" Header="备注" />
                                <DataGridTextColumn MinWidth="100" Binding="{Binding Prompt}" Header="提示" IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </GroupBox>

                <ContentControl Grid.Row="1" Grid.RowSpan="2" Grid.Column="0" Content="{Binding ControllerModel.ControllerConfig}" />
                <ContentControl Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Content="{Binding ControllerModel.AxisConfig}" />
            </Grid>
        </TabItem>


    </TabControl>
</UserControl>
