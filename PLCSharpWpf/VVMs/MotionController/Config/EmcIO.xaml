<UserControl x:Class="PLCSharp.VVMs.MotionController.Config.EmcIO"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controllers="clr-namespace:PLCSharp.VVMs.MotionController"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PLCSharp.VVMs.MotionController.Config"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=controllers:ControllersModel}"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="AliceBlue">
    <Grid>
        <GroupBox Grid.Row="1" Grid.RowSpan="2" Grid.Column="0" Header="通用IO">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />

                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.ColumnSpan="2" VerticalAlignment="Center" Orientation="Horizontal">


                    <Button Width="50" Margin="10,0"
                            Command="{Binding IOManage}"
                            CommandParameter="Import" Content="导入" />
                    <Button Width="50" Margin="10,0"
                            Command="{Binding IOManage}"
                            CommandParameter="Export" Content="导出" />
                    <Button Width="50" Margin="10,0"
                            Command="{Binding IOManage}"
                            CommandParameter="Save" Content="保存" />
                </StackPanel>
                <GroupBox Grid.Row="1" Grid.Column="0"
                          Grid.RowSpan="2"
                          Margin="5"
                          Header="输入">
                    <Grid>
                        <DataGrid Width="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualWidth}"
                                  Height="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualHeight}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  CanUserDeleteRows="False" CanUserSortColumns="False"
                                  ItemsSource="{Binding SelectedController.DI}"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  Unloaded="DataGrid_Unloaded">

                            <DataGrid.Columns>
                                <DataGridTextColumn MinWidth="60" Binding="{Binding Number}" Header="序号" />
                                <DataGridTextColumn MinWidth="60" Binding="{Binding LineNumber}" Header="线号" />
                                <DataGridTextColumn MinWidth="100" Binding="{Binding Name, UpdateSourceTrigger=LostFocus}" Header="名称" />
                                <DataGridTemplateColumn Header="状态">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Viewbox>
                                                <Ellipse Width="10" Height="10" Fill="{Binding Status, Converter={StaticResource BoolToValueConverter}, Mode=TwoWay, ConverterParameter=Lime, FallbackValue=Gray}" />
                                            </Viewbox>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </GroupBox>
                <GroupBox Grid.Row="1" Grid.Column="1"
                          Grid.RowSpan="2"
                          Margin="5"
                          Header="输出">
                    <Grid>
                        <DataGrid Width="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualWidth}"
                                  Height="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualHeight}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  CanUserDeleteRows="False" CanUserSortColumns="False"
                                  ItemsSource="{Binding SelectedController.DQ}"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  Unloaded="DataGrid_Unloaded">

                            <DataGrid.Columns>
                                <DataGridTextColumn MinWidth="60" Binding="{Binding Number}" Header="序号" IsReadOnly="True" />
                                <DataGridTextColumn MinWidth="60" Binding="{Binding LineNumber}" Header="线号" />
                                <DataGridTextColumn MinWidth="100" Binding="{Binding Name, UpdateSourceTrigger=LostFocus}" Header="名称" />
                                <DataGridTemplateColumn Header="状态">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Viewbox>
                                                <Ellipse Width="10" Height="10" Fill="{Binding Status, Converter={StaticResource BoolToValueConverter}, Mode=TwoWay, ConverterParameter=Lime, FallbackValue=Gray}" />
                                            </Viewbox>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </GroupBox>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
