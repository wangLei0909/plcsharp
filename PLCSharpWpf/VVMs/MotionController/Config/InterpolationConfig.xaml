<UserControl x:Class="PLCSharp.VVMs.MotionController.Config.InterpolationConfig"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PLCSharp.VVMs.MotionController"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:Background="AliceBlue"
             d:DataContext="{d:DesignInstance Type=local:ControllersModel}"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3*" />
            <RowDefinition Height="1*" />

        </Grid.RowDefinitions>
        <Grid Tag="数据">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <GroupBox Header="插补段">
                <Grid>
                    <DataGrid Width="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualWidth}"
                              Height="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualHeight}"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              CanUserDeleteRows="False" CanUserSortColumns="False"
                              ItemsSource="{Binding InterpolationGroups}"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              SelectedItem="{Binding SelectedInterpolationGroup}"
                              Unloaded="DataGrid_Unloaded">
                        <DataGrid.ContextMenu>
                            <ContextMenu IsEnabled="True" StaysOpen="False">
                                <MenuItem Command="{Binding InterpolationsGroupManage}" CommandParameter="New" Header="新增" />
                                <MenuItem Command="{Binding InterpolationsGroupManage}" CommandParameter="Remove" Header="删除" />
                                <MenuItem Command="{Binding InterpolationsGroupManage}" CommandParameter="Save" Header="保存" />
                                <MenuItem Command="{Binding InterpolationsGroupManage}" CommandParameter="Go" Header="Go" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn MinWidth="100" Binding="{Binding Name, UpdateSourceTrigger=LostFocus}" Header="名称" />
                            <DataGridTextColumn MinWidth="100" Binding="{Binding Prompt, UpdateSourceTrigger=LostFocus}" Header="提示" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>
            <GroupBox Grid.Column="1" Header="插补表">
                <Grid>
                    <DataGrid Width="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualWidth}"
                              Height="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualHeight}"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              CanUserDeleteRows="False" CanUserSortColumns="False"
                              ItemsSource="{Binding SelectedInterpolationGroup.Interpolations}"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              SelectedItem="{Binding SelectedInterpolation}"
                              Unloaded="DataGrid_Unloaded">
                        <DataGrid.ContextMenu>
                            <ContextMenu IsEnabled="True" StaysOpen="False">
                                <MenuItem Command="{Binding InterpolationsManage}" CommandParameter="NewLine" Header="新增直线插补" />
                                <MenuItem Command="{Binding InterpolationsManage}" CommandParameter="NewArc" Header="新增圆弧插补" />
                                <MenuItem Command="{Binding InterpolationsManage}" CommandParameter="MoveUp" Header="上移" />
                                <MenuItem Command="{Binding InterpolationsManage}" CommandParameter="MoveDown" Header="下移" />
                                <MenuItem Command="{Binding InterpolationsManage}" CommandParameter="Remove" Header="删除" />
                                <MenuItem Command="{Binding InterpolationsManage}" CommandParameter="Save" Header="保存" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>

                            <DataGridTextColumn MinWidth="100" Binding="{Binding Name, UpdateSourceTrigger=LostFocus}" Header="名称" />
                            <DataGridTextColumn MinWidth="100" Binding="{Binding Type}" Header="类型" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>
            <GroupBox Grid.Column="2" Header="点位表">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*" />
                        <RowDefinition Height="1*" />

                    </Grid.RowDefinitions>
                    <Grid>
                        <DataGrid Width="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualWidth}"
                                  Height="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}, AncestorLevel=1}, Path=ActualHeight}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  CanUserDeleteRows="False" CanUserSortColumns="False"
                                  ItemsSource="{Binding SelectedInterpolation.InterpolationPoints}"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  SelectedItem="{Binding SelectedInterpolationPoint}"
                                  Unloaded="DataGrid_Unloaded">
                            <DataGrid.ContextMenu>
                                <ContextMenu IsEnabled="True" StaysOpen="False">
                                    <MenuItem Command="{Binding InterpolationPointCommand}" CommandParameter="Go" Header="Go" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>

                                <DataGridTextColumn MinWidth="100" Binding="{Binding Name, UpdateSourceTrigger=LostFocus}" Header="名称" />
                                <DataGridTextColumn MinWidth="100" Binding="{Binding X, UpdateSourceTrigger=LostFocus}" Header="X" />
                                <DataGridTextColumn MinWidth="100" Binding="{Binding Y, UpdateSourceTrigger=LostFocus}" Header="Y" />

                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                    <GroupBox Grid.Row="1" Header="点位参数">
                        <UniformGrid Columns="2">
                            <TextBlock Margin="3"
                                       Text="圆弧方向" FontSize="14" FontWeight="Bold"
                                       VerticalAlignment="Center" />
                            <ComboBox Height="30" Margin="3"
                                      FontSize="14" FontWeight="Bold"
                                      SelectedIndex="{Binding SelectedInterpolation.Params.Dir}">
                                <ComboBoxItem Content="顺时针" />
                                <ComboBoxItem Content="逆时针" />
                            </ComboBox>
                            <TextBlock Margin="3"
                                       Text="位置模式" FontSize="14" FontWeight="Bold"
                                       VerticalAlignment="Center" />
                            <ComboBox Height="30" Margin="3"
                                      FontSize="14" FontWeight="Bold"
                                      SelectedIndex="{Binding SelectedInterpolation.Params.PositionMode}">
                                <ComboBoxItem Content="相对" />
                                <ComboBoxItem Content="绝对" />
                            </ComboBox>
                            <!--<TextBlock Margin="3"
                                   Text=" " FontSize="14" FontWeight="Bold"
                                   VerticalAlignment="Center" />
                        <TextBox Height="30" Text=" " FontSize="14" FontWeight="Bold" />
                        <TextBlock Margin="3"
                                   Text=" " FontSize="14" FontWeight="Bold"
                                   VerticalAlignment="Center" />
                        <TextBox Height="30" MinWidth="60"
                                 Text=" " FontSize="14" FontWeight="Bold" />
                        <TextBlock Margin="3"
                                   Text=" " FontSize="14" FontWeight="Bold"
                                   VerticalAlignment="Center" />-->
                            <Button Command="{Binding InterpolationsGroupManage}" CommandParameter="Save" Content="保存" />


                        </UniformGrid>
                    </GroupBox>

                </Grid>
            </GroupBox>
            <Grid Grid.Column="3" Grid.ColumnSpan="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                <Grid MinHeight="200" Tag="设置">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*" />
                        <RowDefinition Height="1*" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>
                    <GroupBox Header="速率">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="2*" />
                                <RowDefinition Height="2*" />

                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />

                            </Grid.ColumnDefinitions>
                            <!--  X轴  -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="X轴：" />
                            <ComboBox Grid.Row="0" Grid.Column="1"
                                      DisplayMemberPath="Name"
                                      ItemsSource="{Binding Axes}"
                                      SelectedItem="{Binding SelectedInterpolationGroup.AxisX, UpdateSourceTrigger=PropertyChanged}" />


                            <!--  Y轴  -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Y轴：" />
                            <ComboBox Grid.Row="1" Grid.Column="1"
                                      DisplayMemberPath="Name"
                                      ItemsSource="{Binding Axes}"
                                      SelectedItem="{Binding SelectedInterpolationGroup.AxisY, UpdateSourceTrigger=PropertyChanged}" />


                        </Grid>
                    </GroupBox>

                </Grid>
                <Grid Grid.Row="1" Grid.RowSpan="2">
                    <UniformGrid Columns="2">
                        <TextBlock Margin="3"
                                   Text="加速度" FontSize="14" FontWeight="Bold"
                                   VerticalAlignment="Center" />

                        <TextBox Height="30" MinWidth="40"
                                 Text="{Binding SelectedInterpolationGroup.Params.Acc}"
                                 FontSize="14" FontWeight="Bold" />
                        <TextBlock Margin="3"
                                   Text="减速度" FontSize="14" FontWeight="Bold"
                                   VerticalAlignment="Center" />
                        <TextBox Height="30" MinWidth="40"
                                 Text="{Binding SelectedInterpolationGroup.Params.Dec}"
                                 FontSize="14" FontWeight="Bold" />
                        <TextBlock Margin="3"
                                   Text="启动速度" FontSize="14" FontWeight="Bold"
                                   VerticalAlignment="Center" />
                        <TextBox Height="30" Text="{Binding SelectedInterpolationGroup.Params.MinVelocity}" FontSize="14" FontWeight="Bold" />
                        <TextBlock Margin="3"
                                   Text="最大速度" FontSize="14" FontWeight="Bold"
                                   VerticalAlignment="Center" />
                        <TextBox Height="30" MinWidth="60"
                                 Text="{Binding SelectedInterpolationGroup.Params.MaxVelocity}"
                                 FontSize="14" FontWeight="Bold" />
                        <TextBlock Margin="3"
                                   Text="停止速度" FontSize="14" FontWeight="Bold"
                                   VerticalAlignment="Center" />
                        <TextBox Height="30" Text="{Binding SelectedInterpolationGroup.Params.StopVelocity}" FontSize="14" FontWeight="Bold" />


                    </UniformGrid>
                </Grid>

            </Grid>
        </Grid>


        <Grid Grid.Row="1" Tag="操作">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="4*" />
            </Grid.ColumnDefinitions>
            <GroupBox Header="点动">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Row="1" Grid.Column="2"
                            Margin="5,0"
                            Command="{Binding InterpolationPointCommand}"
                            CommandParameter="X+" Content="X+" />
                    <Button Grid.Row="1" Grid.Column="0"
                            Margin="5,0"
                            Command="{Binding InterpolationPointCommand}"
                            CommandParameter="X-" Content="X-" />

                    <Button Grid.Row="0" Grid.Column="1"
                            Margin="10,0"
                            Command="{Binding InterpolationPointCommand}"
                            CommandParameter="Y+" Content="Y+" />
                    <Button Grid.Row="2" Grid.Column="1"
                            Margin="10,0"
                            Command="{Binding InterpolationPointCommand}"
                            CommandParameter="Y-" Content="Y-" />

                    <Button Grid.Row="1" Grid.Column="1"
                            Margin="3" Padding="15,3"
                            FontSize="14" FontWeight="Bold"
                            Background="Red"
                            Command="{Binding InterpolationPointCommand}"
                            CommandParameter="Stop" Content="STOP" />
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="当前位置">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />

                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="X轴：" />
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding SelectedInterpolationGroup.AxisX.CommandPosition}" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Y轴：" />
                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding SelectedInterpolationGroup.AxisY.CommandPosition}" />


                    <Button Grid.Row="4" Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Command="{Binding InterpolationPointCommand}"
                            CommandParameter="Save" Content="保存到选中点" />
                </Grid>
            </GroupBox>
            <GroupBox Grid.Column="2" Header="点动距离">
                <UniformGrid Grid.Column="2" Columns="2">
                    <TextBlock Margin="3"
                               Text="寸动距离" FontSize="14" FontWeight="Bold"
                               VerticalAlignment="Center" />
                    <TextBox Height="30" Margin="3"
                             Text="{Binding RelativeDistance}"
                             FontSize="14" FontWeight="Bold" />

                    <Button Width="50" Margin="3"
                            FontSize="14" FontWeight="Bold"
                            Command="{Binding DistanceSet}"
                            CommandParameter="Jog0.01" Content="0.01" />
                    <Button Width="50" Margin="3"
                            FontSize="14" FontWeight="Bold"
                            Command="{Binding DistanceSet}"
                            CommandParameter="Jog0.1" Content="0.1" />
                    <Button Width="50" Margin="3"
                            FontSize="14" FontWeight="Bold"
                            Command="{Binding DistanceSet}"
                            CommandParameter="Jog1" Content="1" />
                    <Button Width="50" Margin="3"
                            FontSize="14" FontWeight="Bold"
                            Command="{Binding DistanceSet}"
                            CommandParameter="Jog5" Content="5" />
                    <Button Width="50" Margin="3"
                            FontSize="14" FontWeight="Bold"
                            Command="{Binding DistanceSet}"
                            CommandParameter="Jog10" Content="10" />
                    <Button Width="50" Margin="3"
                            FontSize="14" FontWeight="Bold"
                            Command="{Binding DistanceSet}"
                            CommandParameter="Jog20" Content="20" />

                </UniformGrid>
            </GroupBox>
        </Grid>

    </Grid>
</UserControl>
